<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         cacheDirectory=".phpunit.cache"
         failOnRisky="true"
         failOnWarning="true"
         displayDetailsOnTestsThatTriggerWarnings="true"
         displayDetailsOnTestsThatTriggerNotices="true"
         displayDetailsOnTestsThatTriggerDeprecations="true">
    <testsuites>
        <testsuite name="kernel">
            <directory>packages/kernel/tests</directory>
        </testsuite>
        <testsuite name="phpstan-rules">
            <directory>packages/phpstan-rules/tests</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>packages/kernel/src</directory>
            <directory>packages/phpstan-rules/src</directory>
        </include>
    </source>
</phpunit>