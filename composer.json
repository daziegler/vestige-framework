{
    "name": "vestige/vestige",
    "description": "Vestige — a tiny SOLID PHP framework.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "vestige/kernel": "@dev",
        "vestige/phpstan-rules": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.65",
        "rector/rector": "^2.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "packages/kernel",
            "options": {"versions": {"vestige/kernel": "dev-main"}}
        },
        {
            "type": "path",
            "url": "packages/phpstan-rules",
            "options": {"versions": {"vestige/phpstan-rules": "dev-main"}}
        }
    ],
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Vestige\\": "packages/kernel/src/",
      "Vestige\\PhpstanRules\\": "packages/phpstan-rules/src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Vestige\\Tests\\": "packages/kernel/tests/",
      "Vestige\\PhpstanRules\\Tests\\": "packages/phpstan-rules/tests/"
    }
  },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    }
}
