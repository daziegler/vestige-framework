{
    "name": "vestige/kernel",
    "description": "Vestige framework kernel — HTTP kernel, routing, pipeline, errors.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "psr/container": "^2.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "psr/log": "^3.0",
        "nyholm/psr7": "^1.8",
        "nyholm/psr7-server": "^1.1",
        "nikic/fast-route": "^1.3",
        "league/container": "^4.2",
        "monolog/monolog": "^3.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "Vestige\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vestige\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}