{
    "name": "vestige/phpstan-rules",
    "description": "Custom PHPStan rules for Vestige.",
    "type": "phpstan-extension",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "phpstan/phpstan": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "Vestige\\PhpstanRules\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vestige\\PhpstanRules\\Tests\\": "tests/"
        }
    },
    "extra": {
        "phpstan": {
            "includes": ["extension.neon"]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}